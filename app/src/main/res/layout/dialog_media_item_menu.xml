<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/media_item_thumb"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:adjustViewBounds="false"
            android:clickable="true"
            android:contentDescription="@string/thumbnail"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_thumbnail_placeholder" />

        <ImageButton
            android:id="@+id/media_item_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/close"
            android:padding="12dp"
            android:src="@drawable/ic_close"
            app:tint="?attr/colorOnSurface" />
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/media_item_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:ellipsize="end"
                android:maxLines="3"
                android:textIsSelectable="true"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/media_item_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="end"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/action_queue"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/add_to_queue"
                    android:padding="7dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_queue_add"
                    app:tint="?attr/colorOnSurface" />

                <ImageButton
                    android:id="@+id/action_share"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/share"
                    android:padding="7dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_share"
                    app:tint="?attr/colorOnSurface" />

                <ImageButton
                    android:id="@+id/action_download"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/download"
                    android:padding="7dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_download"
                    app:tint="?attr/colorOnSurface" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
